# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3001

# ─── MongoDB Atlas ────────────────────────────────────
# 1. Sign up at https://www.mongodb.com/cloud/atlas
# 2. Create a free M0 cluster
# 3. Network Access → add 0.0.0.0/0 (or your IP)
# 4. Database Access → create a user with readWrite
# 5. Connect → "Drivers" → copy the connection string and paste below
# MONGO_URI=mongodb+srv://<USER>:<PASSWORD>@cluster0.xxxxx.mongodb.net/nanma?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/nanma

# ─── JWT ──────────────────────────────────────────────
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# ─── Default admin (used by `npm run seed:admin`) ─────
ADMIN_EMAIL=admin@nanmaestates.com
ADMIN_PASSWORD=ChangeMe@2026
ADMIN_NAME=Nanma Admin

# ─── Cloudinary ───────────────────────────────────────
# 1. Sign up free at https://cloudinary.com
# 2. Dashboard → "Account Details" — copy the three values below
CLOUDINARY_CLOUD_NAME=dgrkmgfnc
CLOUDINARY_API_KEY=855865969845694
CLOUDINARY_API_SECRET=b_qhcXNIkTWpqca3q27RDThyWSw

# ─── Public site (used in sitemap.xml) ────────────────
PUBLIC_SITE_URL=https://nanmaestates.com
